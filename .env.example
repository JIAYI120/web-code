# 服务器配置
PORT=3000

# MongoDB 配置
MONGO_URI=mongodb://localhost:27017/xiaoyuan

# JWT 配置（请使用 openssl rand -base64 64 生成安全密钥）
JWT_SECRET=your_jwt_secret_key_here_at_least_64_chars

# AI 配置（可选）
XIAOMI_API_KEY=your_api_key_here
XIAOMI_API_BASE_URL=your_api_base_url_here
XIAOMI_MODEL=your_model_here

# 允许的前端域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
